# Copy to .env and fill in. The Nix devshell auto-loads this file.
# (M7 will replace env-based config with an in-app settings UI + OS keyring.)

# Which provider: gemini | mistral | openai | groq | openai-compatible | whisper-local
#   gemini            -> streaming, word-by-word (Gemini Live)
#   mistral           -> chunked transcription (Voxtral, api.mistral.ai)
#   openai / groq     -> chunked Whisper (transcribe per speech segment)
#   openai-compatible -> any /audio/transcriptions endpoint (set BASE_URL+MODEL)
#   whisper-local     -> 100% offline via whisper.cpp (set WHISPER_MODEL path)
TRANSCRIPT_PROVIDER=gemini

# --- gemini ---
# GEMINI_API_KEY / GOOGLE_API_KEY / TRANSCRIPT_API_KEY are all accepted.
GEMINI_API_KEY=

# --- openai (Whisper) ---  TRANSCRIPT_PROVIDER=openai
# OPENAI_API_KEY=
# TRANSCRIPT_MODEL=whisper-1

# --- groq (very fast Whisper) ---  TRANSCRIPT_PROVIDER=groq
# GROQ_API_KEY=
# TRANSCRIPT_MODEL=whisper-large-v3

# --- mistral (Voxtral) ---  TRANSCRIPT_PROVIDER=mistral
# MISTRAL_API_KEY=
# TRANSCRIPT_MODEL=voxtral-mini-latest

# --- generic OpenAI-compatible ---  TRANSCRIPT_PROVIDER=openai-compatible
# TRANSCRIPT_BASE_URL=http://localhost:8000/v1
# TRANSCRIPT_MODEL=whisper-1
# TRANSCRIPT_API_KEY=            # optional for local servers

# --- cleanup / reformulation prompts (post-transcription text engine) ---
# Configured in-app (⚙ → "Moteur de reformulation"). Engine = gemini (reuses
# GEMINI_API_KEY), mistral, groq, openai, or generic openai-compatible.
# Non-gemini engines read the key from the "cleanup" keyring entry, falling back
# to these env vars:
# CLEANUP_API_KEY=
# MISTRAL_API_KEY=          # also used by the mistral cleanup engine

# --- whisper.cpp local (offline) ---  TRANSCRIPT_PROVIDER=whisper-local
# Download a ggml model, e.g.:
#   curl -L -o ~/.cache/whisper/ggml-base.bin \
#     https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.bin
# TRANSCRIPT_WHISPER_MODEL=/home/thomas/.cache/whisper/ggml-base.bin
# TRANSCRIPT_LANGUAGE=fr         # optional; omit for auto-detect

# Optional: override the model. Must be a Live (bidiGenerateContent) model.
# List yours with:
#   curl "https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_API_KEY" \
#     | grep -B2 bidiGenerateContent
# Common native-audio Live models (response is AUDIO, discarded; we use the
# input-audio transcription):
#   gemini-2.5-flash-native-audio-latest
#   gemini-3.1-flash-live-preview
TRANSCRIPT_MODEL=gemini-2.5-flash-native-audio-latest

# Optional: language hint (used by Whisper / OpenAI-compatible providers, M5).
# TRANSCRIPT_LANGUAGE=fr
